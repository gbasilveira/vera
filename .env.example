# Bus backend: blinker (default) | redis | nats
VERA_BUS_BACKEND=blinker

# LLM provider: ollama (default) | openai | anthropic
VERA_LLM_PROVIDER=ollama
VERA_LLM_MODEL=llama3
VERA_LLM_TEMPERATURE=0.1

# Vector store backend: chroma (default) | lancedb | pgvector
VERA_VECTOR_BACKEND=chroma

# Secrets backend: keyring (default) | sqlite
VERA_SECRETS_BACKEND=keyring
# Required if VERA_SECRETS_BACKEND=sqlite:
VERA_MASTER_KEY=

# VFS SQLite path (default: data/vera_vfs.db)
VERA_VFS_PATH=data/vera_vfs.db

# Casbin policy paths
VERA_CASBIN_MODEL=data/casbin/rbac_model.conf
VERA_CASBIN_POLICY=data/casbin/policy.csv

# OpenTelemetry OTLP endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Plugins directory
VERA_PLUGINS_DIR=plugins